{
  "name": "facette",
  "version": "0.1.0",
  "description": "Perceptual color palette generation via particle repulsion on convex hulls in OKLab space",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "docs/assets/*.svg"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "dev": "tsup --watch"
  },
  "keywords": [
    "color",
    "palette",
    "color-palette",
    "oklab",
    "perceptual",
    "color-generation",
    "design"
  ],
  "author": "yrvaneycke",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vanpact/Facette.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/vanpact/Facette#readme",
  "bugs": {
    "url": "https://github.com/vanpact/Facette/issues"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^5.7",
    "vitest": "^3"
  },
  "license": "MIT"
}
